# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-secret-key-here

# WiFi Check (optional)
BYPASS_WIFI_CHECK=true

# Jeda Check (optional) - bypass aturan 6 jam untuk testing
# BYPASS_JEDA_CHECK=true

# Time Check (optional) - bypass validasi jam absen
# BYPASS_TIME_CHECK=true       # server-side: skip validasi jam, sesi auto-detect
# VITE_BYPASS_TIME_CHECK=true  # client-side: tombol pagi+sore selalu aktif

# Pagi Only (optional) - bypass validasi jam KHUSUS pagi
# VITE_BYPASS_PAGI_ONLY=true   # client-side: hanya tombol pagi yang selalu aktif

# Frontend Configuration (dalam development)
VITE_API_URL=http://localhost:5000/api
